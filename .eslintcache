a.akamaihd.net/content/MI201109210084_1/m3u8s/f08e80da-bf1d-4e3d-8899-f0f6155f6efa.m3u8',\n            type: 'application/x-mpegURL',\n          },\n        ],\n        controls: true,\n        ...options,\n      },\n      () => {\n        player.src();\n      }\n    );\n\n    player.on('pause', eventON.pause);\n\n    return () => {\n      player.dispose();\n    };\n  }, []);\n\n  return (\n    <div data-vjs-player>\n      <video ref={playerRef} className='video-js vjs-16-9' playsInline />\n    </div>\n  );\n};\n\nexport default VideoPlayer;\n","/Users/jordan/Desktop/material/project/youtube/src/globalStyles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/LikeList/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/CardLoader/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/Pagination/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/VideoCard/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/Home/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/styles.js",[],["151","152"],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/index.js",[],{"ruleId":"153","replacedBy":"154"},{"ruleId":"155","replacedBy":"156"},{"ruleId":"153","replacedBy":"157"},{"ruleId":"155","replacedBy":"158"},{"ruleId":"153","replacedBy":"159"},{"ruleId":"155","replacedBy":"160"},{"ruleId":"153","replacedBy":"161"},{"ruleId":"155","replacedBy":"162"},{"ruleId":"153","replacedBy":"163"},{"ruleId":"155","replacedBy":"164"},{"ruleId":"153","replacedBy":"165"},{"ruleId":"155","replacedBy":"166"},{"ruleId":"167","severity":1,"message":"168","line":45,"column":6,"nodeType":"169","endLine":45,"endColumn":8,"suggestions":"170"},{"ruleId":"153","replacedBy":"171"},{"ruleId":"155","replacedBy":"172"},"no-native-reassign",["173"],"no-negated-in-lhs",["174"],["173"],["174"],["173"],["174"],["173"],["174"],["173"],["174"],["173"],["174"],"rea