tON.pause);\n\n    return () => {\n      player.dispose();\n    };\n  }, []);\n\n  return (\n    <div data-vjs-player>\n      <video ref={playerRef} className='video-js vjs-16-9' playsInline />\n    </div>\n  );\n};\n\nexport default VideoPlayer;\n","/Users/jordan/Desktop/material/project/youtube/src/globalStyles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/LikeList/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/CardLoader/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/Pagination/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/VideoCard/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/Home/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/index.js",[],{"ruleId":"144","replacedBy":"145"},{"ruleId":"146","replacedBy":"147"},{"ruleId":"144","replacedBy":"148"},{"ruleId":"146","replacedBy":"149"},{"ruleId":"144","replacedBy":"150"},{"ruleId":"146","replacedBy":"151"},{"ruleId":"144","replacedBy":"152"},{"ruleId":"146","replacedBy":"153"},{"ruleId":"154","severity":1,"message":"155","line":45,"column":6,"nodeType":"156","endLine":45,"endColumn":8,"suggestions":"157"},"no-native-reassign",["158"],"no-negated-in-lhs",["159"],["158"],["159"],["158"],["159"],["158"],["159"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'eventON.pause' and 'options'. Either include them or remove the dependency array.","ArrayExpression",["160"],"no-global-assign","no-unsafe-negation",{"desc":"161","fix":"162"},"Update the dependencies array to be: [eventON.pause, options]",{"range":"163","text":"164"},[957,959],"[eventON.pause, options]"]