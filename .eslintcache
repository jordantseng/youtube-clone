-f0f6155f6efa.m3u8',\n            type: 'application/x-mpegURL',\n          },\n        ],\n        controls: true,\n        ...options,\n      },\n      () => {\n        player.src();\n      }\n    );\n\n    player.on('pause', eventON.pause);\n\n    return () => {\n      player.dispose();\n    };\n  }, []);\n\n  return (\n    <div data-vjs-player>\n      <video ref={playerRef} className='video-js vjs-16-9' playsInline />\n    </div>\n  );\n};\n\nexport default VideoPlayer;\n","/Users/jordan/Desktop/material/project/youtube/src/globalStyles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/LikeList/index.js",[],["148","149"],"/Users/jordan/Desktop/material/project/youtube/src/components/CardLoader/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/Pagination/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/components/VideoCard/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/Home/index.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/styles.js",[],"/Users/jordan/Desktop/material/project/youtube/src/pages/VideoDetails/index.js",[],{"ruleId":"150","replacedBy":"151"},{"ruleId":"152","replacedBy":"153"},{"ruleId":"150","replacedBy":"154"},{"ruleId":"152","replacedBy":"155"},{"ruleId":"150","replacedBy":"156"},{"ruleId":"152","replacedBy":"157"},{"ruleId":"150","replacedBy":"158"},{"ruleId":"152","replacedBy":"159"},{"ruleId":"150","replacedBy":"160"},{"ruleId":"152","replacedBy":"161"},{"ruleId":"162","severity":1,"message":"163","line":45,"column":6,"nodeType":"164","endLine":45,"endColumn":8,"suggestions":"165"},{"ruleId":"150","replacedBy":"166"},{"ruleId":"152","replacedBy":"167"},"no-native-reassign",["168"],"no-negated-in-lhs",["169"],["168"],["169"],["168"],["169"],["168"],["169"],["168"],["169"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'eventON.pause' and 'options'. Either include them or remove the dependency array."